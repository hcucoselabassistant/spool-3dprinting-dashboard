# Settings -> API -> "Project URL". The bare origin, with no path.
# Not the REST URL (.../rest/v1) -- the client appends its own paths, and a
# pasted REST URL makes every sign-in fail as if the password were wrong.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Not used by any code, and nothing in the build plan needs it -- RLS covers the
# app. Leave it empty unless something genuinely has to bypass RLS, and never
# give it a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_TIMEZONE=America/Chicago
NEXT_PUBLIC_LOW_SPOOL_GRAMS=150
NEXT_PUBLIC_PICKUP_STALE_HOURS=48
