# Settings -> API -> "Project URL". The bare origin, with no path.
# Not the REST URL (.../rest/v1) -- the client appends its own paths, and a
# pasted REST URL makes every sign-in fail as if the password were wrong.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for in-app user management (/settings/users) -- creating an auth
# account needs the Admin API. Bypasses all RLS, so it is server-only: never
# give it a NEXT_PUBLIC_ prefix, and set it in Vercel as a server variable.
SUPABASE_SERVICE_ROLE_KEY=

# Only used by `supabase gen types`, never by the app. Use the SESSION POOLER
# string from Settings -> Database, not the direct connection -- the direct host
# is IPv6-only and unreachable on many networks.
SUPABASE_DB_URL=

NEXT_PUBLIC_TIMEZONE=America/Chicago
NEXT_PUBLIC_LOW_SPOOL_GRAMS=150
NEXT_PUBLIC_PICKUP_STALE_HOURS=48
